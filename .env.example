# Copy this file to .env and fill in your keys

# Required: Tavily API key (free tier: 1000 searches/month)
# Sign up at https://tavily.com
TAVILY_API_KEY=

# Optional: KeywordsPeopleUse API key
# Sign up at https://keywordspeopleuse.com
KEYWORDS_PEOPLE_USE_API_KEY=

# Optional: SEMrush API key (requires SEMrush API subscription)
# Enables: search volume, keyword difficulty, competitor analysis
SEMRUSH_API_KEY=

# Optional: HubSpot CMS — Private App token with 'content' scope
# Create at: HubSpot Settings > Integrations > Private Apps
# Enables: push article drafts to HubSpot CMS
HUBSPOT_ACCESS_TOKEN=

# Optional: HubSpot Blog contentGroupId
# Auto-detected from existing posts if omitted
HUBSPOT_CONTENT_GROUP_ID=

# Optional: Asana Personal Access Token
# Create at: https://app.asana.com/0/my-apps
# Enables: update Asana tasks when publishing to HubSpot
ASANA_ACCESS_TOKEN=

# Optional: Asana workspace GID
# Visible in Asana URL or via GET /users/me/workspaces
ASANA_WORKSPACE_GID=
